rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Hardcoded primary admin to prevent recursion and bootstrap the system
    function isPrimaryAdmin() {
      return isSignedIn() && request.auth.token.email == 'friendswatchgotforfree@gmail.com' && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isPrimaryAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isValidAudit(data) {
      return data.url is string && data.url.size() < 2048
          && data.overallScore is number && data.overallScore >= 0 && data.overallScore <= 100
          && data.summary is string && data.summary.size() < 15000
          && data.businessDomain is string && data.businessDomain.size() < 1000
          && data.persuasiveCallToAction is string && data.persuasiveCallToAction.size() < 15000
          && data.timestamp is string
          && data.userId == request.auth.uid
          && data.generatedBy is string
          && data.userEmail is string
          && data.riskLevel in ['critical', 'elevated', 'stable'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isPrimaryAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId 
          && (
            (incoming().role == 'user' && request.auth.token.email != 'friendswatchgotforfree@gmail.com') ||
            (incoming().role == 'admin' && request.auth.token.email == 'friendswatchgotforfree@gmail.com')
          )
          && incoming().tier == 'free'
          && incoming().auditsUsed == 0;
      allow update: if isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'tier', 'auditsUsed', 'auditQuota']));
      allow delete: if isAdmin();
    }

    match /audits/{auditId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isVerified() 
          && isValidAudit(incoming())
          && !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned
          && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.auditQuota > get(/databases/$(database)/documents/users/$(request.auth.uid)).data.auditsUsed 
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.auditQuota == -1);

      // Audits are immutable once created
      allow update, delete: if isAdmin();
    }

    match /tiers/{tierId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
