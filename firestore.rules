rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidAudit(data) {
      return data.url is string && data.url.size() < 2000
          && data.overallScore is number && data.overallScore >= 0 && data.overallScore <= 100
          && data.summary is string && data.summary.size() < 10000
          && data.businessDomain is string && data.businessDomain.size() < 500
          && data.persuasiveCallToAction is string && data.persuasiveCallToAction.size() < 10000
          && data.timestamp is string
          && data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId 
          && (
            (incoming().role == 'user' && request.auth.token.email != 'friendswatchgotforfree@gmail.com') ||
            (incoming().role == 'admin' && request.auth.token.email == 'friendswatchgotforfree@gmail.com')
          )
          && incoming().tier == 'free'
          && incoming().auditsUsed == 0;
      allow update: if isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['email', 'tier', 'auditsUsed']));
      allow delete: if isAdmin();
    }

    match /audits/{auditId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() 
          && isValidAudit(incoming())
          && !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned
          && incoming().keys().hasAll(['url', 'overallScore', 'summary', 'timestamp', 'userId', 'categories', 'businessDomain', 'persuasiveCallToAction'])
          && incoming().keys().size() == 8;

      // Audits are immutable once created
      allow update, delete: if isAdmin();
    }

    match /tiers/{tierId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
