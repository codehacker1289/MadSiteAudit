{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User authentication and subscription data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "tier": { "type": "string", "enum": ["free", "specialist", "strategic_agent"] },
        "auditQuota": { "type": "integer" },
        "auditsUsed": { "type": "integer" },
        "isBanned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "tier", "auditQuota", "auditsUsed", "createdAt"]
    },
    "Audit": {
      "title": "Audit Report",
      "description": "Generated strategic audit report",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "overallScore": { "type": "integer" },
        "url": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "businessDomain": { "type": "string" },
        "summary": { "type": "string" },
        "persuasiveCallToAction": { "type": "string" },
        "strategicVision": { "type": "string" },
        "psychologicalImpact": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["critical", "elevated", "stable"] },
        "generatedBy": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["userId", "overallScore", "url", "timestamp"]
    },
    "PricingTier": {
      "title": "Pricing Tier",
      "description": "Subscription tier configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "quota": { "type": "integer" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "description", "quota"]
    },
    "Settings": {
      "title": "System Settings",
      "description": "Global administrative settings",
      "type": "object",
      "properties": {
        "googlePayId": { "type": "string" },
        "merchantName": { "type": "string" },
        "geminiApiKey": { "type": "string" }
      },
      "required": ["googlePayId", "merchantName"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Profiles for all users"
    },
    "audits/{auditId}": {
      "schema": "Audit",
      "description": "All generated audit reports"
    },
    "tiers/{tierId}": {
      "schema": "PricingTier",
      "description": "Available subscription tiers"
    },
    "settings/admin": {
      "schema": "Settings",
      "description": "Global admin configuration"
    }
  }
}
